{
  "manifest_version": 3,
  "name": "Blocky Web",
  "version": "2.3.1",
  "description": "Bring back the boxy web.",
  "author": "Antonin Sioly",

  "permissions": ["storage", "tabs"],
  "host_permissions": ["<all_urls>"],

  "action": {
    "default_icon": "assets/icons/icon-active.svg",
    "default_popup": "src/ui/popup.html",
    "default_title": "Blocky Web"
  },

  "background": {
    "scripts": ["src/scripts/background.js"],
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/scripts/content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["src/styles/inject.css"],
      "matches": ["<all_urls>"]
    }
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "{c5c7ab24-44c6-46dc-a7e6-bcd163876f22}",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "icons": {
    "16": "assets/icons/icon-active.svg",
    "32": "assets/icons/icon-active.svg",
    "48": "assets/icons/icon-active.svg",
    "64": "assets/icons/icon-active.svg",
    "128": "assets/icons/icon-active.svg"
  }
}
